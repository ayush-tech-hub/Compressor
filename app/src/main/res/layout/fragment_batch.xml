<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <!-- Add buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/card_margin">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddImages"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/add_images"
            app:icon="@drawable/ic_image" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddPdfs"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/add_pdfs"
            app:icon="@drawable/ic_pdf" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/textEmptyBatch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/batch_empty_hint"
        android:textSize="14sp"
        android:textColor="?android:textColorSecondary" />

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBatch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Overall progress -->
    <ProgressBar
        android:id="@+id/progressOverall"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:visibility="gone" />

    <!-- Status / ETA -->
    <TextView
        android:id="@+id/textBatchStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textEta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearAll"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/clear_all" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStartCompression"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="@string/start_compression"
            android:enabled="false"
            app:icon="@drawable/ic_compress" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonShareAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/share_all_completed"
        android:visibility="gone"
        app:icon="@drawable/ic_share" />

</LinearLayout>
