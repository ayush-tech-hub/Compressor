<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- PDF Icon + File Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="@dimen/card_margin"
            android:minHeight="120dp">

            <ImageView
                android:id="@+id/imagePdfIcon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_pdf"
                app:tint="?attr/colorPrimary"
                android:visibility="gone"
                android:contentDescription="@string/pdf_file" />

            <TextView
                android:id="@+id/textNoPdfSelected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_pdf_selected"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary" />

            <TextView
                android:id="@+id/textPdfFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="middle"
                tools:text="document.pdf" />
        </LinearLayout>

        <!-- Select Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectPdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            android:text="@string/select_pdf" />

        <!-- Compression Level -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/compression_level_label"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioLow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/level_low" />

                    <RadioButton
                        android:id="@+id/radioBalanced"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/level_balanced" />

                    <RadioButton
                        android:id="@+id/radioMaximum"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/level_maximum" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- File Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFileInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textOriginalSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"
                    tools:text="Original: 5.2 MB" />

                <TextView
                    android:id="@+id/textEstimatedSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    tools:text="Estimated: 2.8 MB" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Custom Compression Toggle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchCustomMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/use_custom_mode"
                    android:textSize="15sp" />

                <!-- Custom controls (shown when switch is ON) -->
                <LinearLayout
                    android:id="@+id/layoutCustomControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <!-- Image Quality -->
                    <TextView
                        android:id="@+id/textPdfQualityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_image_quality_label"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <SeekBar
                        android:id="@+id/seekBarPdfQuality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="90"
                        android:progress="50"
                        android:layout_marginBottom="16dp" />

                    <!-- DPI -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_dpi_label"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/radioGroupDpi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <RadioButton
                            android:id="@+id/radioDpiOriginal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:checked="true"
                            android:text="@string/dpi_original" />

                        <RadioButton
                            android:id="@+id/radioDpi300"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dpi_300" />

                        <RadioButton
                            android:id="@+id/radioDpi150"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dpi_150" />

                        <RadioButton
                            android:id="@+id/radioDpi72"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dpi_72" />
                    </RadioGroup>

                    <!-- Target File Size -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_target_size_label"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTargetSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipNoLimit"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/target_no_limit" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip10mb"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_10mb" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip5mb"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_5mb" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip1mb"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_1mb" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip500kb"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_500kb" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Remove Metadata -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchRemoveMetadata"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/remove_metadata" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remove_metadata_desc"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCompressCustom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:enabled="false"
                        android:text="@string/compress_button"
                        app:icon="@drawable/ic_compress" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressCompressing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/card_margin"
            android:visibility="gone" />

        <!-- Compress Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCompress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/compress_button"
            android:enabled="false"
            android:layout_marginBottom="@dimen/card_margin"
            app:icon="@drawable/ic_compress" />

        <!-- Result Group -->
        <LinearLayout
            android:id="@+id/groupResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/compression_complete"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Result summary line -->
                    <TextView
                        android:id="@+id/textResultDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/textResultOriginal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/textResultCompressed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/textResultSaved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonShare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/share"
                app:icon="@drawable/ic_share" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/save_to_downloads"
                app:icon="@drawable/ic_save" />

            <TextView
                android:id="@+id/textSavedPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="12sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"
                android:paddingStart="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenFolder"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/open_folder"
                app:icon="@drawable/ic_folder_open" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
